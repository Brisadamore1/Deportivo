<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="AppMovil.Pages.RecuperarPasswordPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:AppMovil.ViewModels"
             Title="Recuperar Contraseña"
             BackgroundColor="White"
             Shell.NavBarIsVisible="False">

    <ContentPage.BindingContext>
        <viewModels:RecuperarPasswordViewModel />
    </ContentPage.BindingContext>
    <Grid RowDefinitions="*">

        <ScrollView>
            <VerticalStackLayout Padding="16,4,16,8" Spacing="8" VerticalOptions="Start" BackgroundColor="White">

                <AbsoluteLayout HeightRequest="220">
                    <Image Source="logo.png"
                           Aspect="AspectFit"
                           HeightRequest="220"
                           AbsoluteLayout.LayoutBounds="0.5,0.5,220,220"
                           AbsoluteLayout.LayoutFlags="PositionProportional" />

                    <ImageButton Command="{Binding VolverCommand}"
                                 BackgroundColor="Transparent"
                                 WidthRequest="48"
                                 HeightRequest="48"
                                 CornerRadius="10"
                                 AbsoluteLayout.LayoutBounds="0,0.3,48,48"
                                 AbsoluteLayout.LayoutFlags="PositionProportional">
                        <ImageButton.Source>
                            <FontImageSource Glyph="&#x2190;" FontFamily="OpenSansRegular" Color="Black" Size="20" />
                        </ImageButton.Source>
                    </ImageButton>
                </AbsoluteLayout>

            <!-- Recuadro (Border) que contiene título, textos, entry y botón (márgenes igual a LoginPage) -->
            <Border BackgroundColor="White"
                    Stroke="#CFCFCF"
                    StrokeThickness="1"
                    Margin="0,-12,0,28">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>

                <VerticalStackLayout Padding="24,20,24,20" Spacing="10">

                    <!-- Título -->
                    <Label Text="Recuperar contraseña"
                           FontAttributes="Bold"
                           FontSize="22"
                           HorizontalOptions="Center"
                           TextColor="#111" />

                    <!-- Texto instructivo -->
                    <Label Text="Ingresá tu correo electrónico y te enviaremos las instrucciones para restablecer tu contraseña"
                           FontSize="14"
                           TextColor="#666"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"
                           LineBreakMode="WordWrap" />

                    <!-- Campo de email (estilo dentro del recuadro) -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Correo electrónico" FontSize="14" TextColor="#222" />
                        <Border BackgroundColor="White"
                            Stroke="#CFCFCF"
                            StrokeThickness="2"
                            HorizontalOptions="Fill"
                            Padding="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="40, *" ColumnSpacing="0" HeightRequest="50">
                                <Label Text="📧"
                                    FontSize="14"
                                    VerticalOptions="Center"
                                    HorizontalOptions="Center"
                                    Margin="12,0" />
                                <Entry Grid.Column="1"
                                    Placeholder="tu@email.com"
                                    Keyboard="Email"
                                    Text="{Binding Mail}"
                                    BackgroundColor="Transparent"
                                    TextColor="Black"
                                    PlaceholderColor="#999"
                                    FontSize="15"
                                    VerticalOptions="Center"
                                    VerticalTextAlignment="Center" />
                            </Grid>
                        </Border>
                    </VerticalStackLayout>
                    
                    <!-- Botón enviar dentro del recuadro -->
                    <Button Text="ENVIAR"
                            Command="{Binding EnviarCommand}"
                            BackgroundColor="Black"
                            TextColor="White"
                            CornerRadius="8"
                            HeightRequest="50"
                            HorizontalOptions="Fill"
                            FontAttributes="Bold"
                            FontSize="16"
                            Margin="0,6,0,0" />
                    <!-- Texto instructivo -->
                    <Label Text="¿No llegó el correo? Revisá tu carpeta de Spam o No deseados."
                            FontSize="14"
                            TextColor="#666"
                            HorizontalOptions="Center"
                            HorizontalTextAlignment="Center"
                            LineBreakMode="WordWrap" />

                    <StackLayout IsVisible="{Binding IsBusy}"
                            Orientation="Horizontal"
                            HorizontalOptions="Center"
                            Spacing="10">  
                        <ActivityIndicator IsRunning="{Binding IsBusy}"
                                Color="#666" />
                        <Label Text="Enviando instrucciones..."
                                TextColor="#666"
                                VerticalOptions="Center"
                                FontSize="14" />
                    </StackLayout>
                    <!-- Mensajes y estado -->
                    <StackLayout Spacing="8">
                        <Label Text="{Binding ErrorMessage}"
                                TextColor="#E74C3C"
                                FontSize="14"
                                HorizontalOptions="Center"
                                HorizontalTextAlignment="Center"
                                IsVisible="{Binding HasError}"
                                LineBreakMode="WordWrap" />

                        <Label Text="{Binding SuccessMessage}"
                                TextColor="#27AE60"
                                FontSize="14"
                                HorizontalOptions="Center"
                                HorizontalTextAlignment="Center"
                                IsVisible="{Binding HasSuccess}"
                                FontAttributes="Bold"
                                LineBreakMode="WordWrap" />
                    </StackLayout>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</Grid>
</ContentPage>