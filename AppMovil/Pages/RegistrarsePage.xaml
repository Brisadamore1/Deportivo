<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:AppMovil.ViewModels"
             x:Class="AppMovil.Pages.RegistrarsePage"
             Title="Crear Cuenta"
             BackgroundColor="White">
    <ContentPage.BindingContext>
        <viewmodels:RegistrarseViewModel />
    </ContentPage.BindingContext>
    <ScrollView>
        <VerticalStackLayout Padding="16,4,16,8" Spacing="8" VerticalOptions="Start">

            <!-- Logo (fill horizontally, AspectFit) with back button -->
            <AbsoluteLayout HeightRequest="220">
                <Image Source="logo.png"
                       Aspect="AspectFit"
                       HeightRequest="220"
                       AbsoluteLayout.LayoutBounds="0.5,0.5,220,220"
                       AbsoluteLayout.LayoutFlags="PositionProportional" />

                <ImageButton Command="{Binding VolverCommand}"
                             BackgroundColor="Transparent"
                             WidthRequest="48"
                             HeightRequest="48"
                             CornerRadius="10"
                             AbsoluteLayout.LayoutBounds="0,0.3,48,48"
                             AbsoluteLayout.LayoutFlags="PositionProportional">
                    <ImageButton.Source>
                        <FontImageSource Glyph="&#x2190;" FontFamily="OpenSansRegular" Color="Black" Size="20" />
                    </ImageButton.Source>
                </ImageButton>
            </AbsoluteLayout>

            <!-- Card like LoginPage -->
            <Border BackgroundColor="White"
                    Stroke="#CFCFCF"
                    StrokeThickness="1"
                    Margin="0,-12,0,28">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>

                <VerticalStackLayout Padding="24,20,24,20" Spacing="10">

                    <!-- Título -->
                    <Label Text="Crear cuenta"
                           FontAttributes="Bold"
                           FontSize="26"
                           HorizontalOptions="Center"
                           TextColor="#111" />

                    <Label Text="Completá tus datos para registrarte"
                           FontSize="14"
                           TextColor="#666"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"
                           Margin="0,0,0,6" />

                    <!-- Nombre -->
                    <VerticalStackLayout Spacing="6" HorizontalOptions="Fill">
                        <Label Text="Apellido y Nombre" FontSize="14" TextColor="#222" />
                        <Border BackgroundColor="White"
                                Stroke="#CFCFCF"
                                StrokeThickness="2"
                                HorizontalOptions="Fill"
                                Padding="0"
                                Margin="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="40, *" ColumnSpacing="0" HeightRequest="50" Margin="0">
                                <Label Text="👤"
                                       FontSize="14"
                                       VerticalOptions="Center"
                                       HorizontalOptions="Center"
                                       Margin="12,0" />
                                <Entry Grid.Column="1"
                                       Text="{Binding Nombre}"
                                       Placeholder="Ej: Juan Perez"
                                       BackgroundColor="Transparent"
                                       TextColor="Black"
                                       PlaceholderColor="#999"
                                       FontSize="15"
                                       VerticalOptions="Center"
                                       VerticalTextAlignment="Center" />
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <!-- DNI -->
                    <VerticalStackLayout Spacing="6" HorizontalOptions="Fill">
                        <Label Text="DNI" FontSize="14" TextColor="#222" />
                        <Border BackgroundColor="White"
                                Stroke="#CFCFCF"
                                StrokeThickness="2"
                                HorizontalOptions="Fill"
                                Padding="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="40, *" ColumnSpacing="0" HeightRequest="50">
                                <Label Text="🆔"
                                       FontSize="14"
                                       VerticalOptions="Center"
                                       HorizontalOptions="Center"
                                       Margin="12,0" />
                                <Entry Grid.Column="1"
                                       Text="{Binding Dni}"
                                       Placeholder="Solo números"
                                       BackgroundColor="Transparent"
                                       TextColor="Black"
                                       PlaceholderColor="#999"
                                       FontSize="15"
                                       VerticalOptions="Center"
                                       VerticalTextAlignment="Center" />
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Teléfono -->
                    <VerticalStackLayout Spacing="6" HorizontalOptions="Fill">
                        <Label Text="Teléfono" FontSize="14" TextColor="#222" />
                        <Border BackgroundColor="White"
                                Stroke="#CFCFCF"
                                StrokeThickness="2"
                                HorizontalOptions="Fill"
                                Padding="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="40, *" ColumnSpacing="0" HeightRequest="50">
                                <Label Text="📞"
                                       FontSize="14"
                                       VerticalOptions="Center"
                                       HorizontalOptions="Center"
                                       Margin="12,0" />
                                <Entry Grid.Column="1"
                                       Text="{Binding Telefono}"
                                       Placeholder="Sin 0 ni 15"
                                       BackgroundColor="Transparent"
                                       TextColor="Black"
                                       PlaceholderColor="#999"
                                       FontSize="15"
                                       VerticalOptions="Center"
                                       VerticalTextAlignment="Center" />
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Rol (read-only) -->
                    <VerticalStackLayout Spacing="6" HorizontalOptions="Fill">
                        <Label Text="Rol" FontSize="14" TextColor="#222" />
                        <Border BackgroundColor="White"
                                Stroke="#CFCFCF"
                                StrokeThickness="2"
                                HorizontalOptions="Fill"
                                Padding="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="40, *" ColumnSpacing="0" HeightRequest="50">
                                <Label Text="🏷️"
                                       FontSize="14"
                                       VerticalOptions="Center"
                                       HorizontalOptions="Center"
                                       Margin="12,0" />
                                <Entry Grid.Column="1"
                                       Text="{Binding TipoRol}"
                                       IsReadOnly="True"
                                       BackgroundColor="Transparent"
                                       TextColor="Black"
                                       PlaceholderColor="#999"
                                       FontSize="15"
                                       VerticalOptions="Center"
                                       VerticalTextAlignment="Center" />
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Email -->
                    <VerticalStackLayout Spacing="6" HorizontalOptions="Fill">
                        <Label Text="Correo electrónico" FontSize="14" TextColor="#222" />
                        <Border BackgroundColor="White"
                                Stroke="#CFCFCF"
                                StrokeThickness="2"
                                HorizontalOptions="Fill"
                                Padding="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="40, *" ColumnSpacing="0" HeightRequest="50">
                                <Label Text="📧"
                                       FontSize="14"
                                       VerticalOptions="Center"
                                       HorizontalOptions="Center"
                                       Margin="12,0" />
                                <Entry Grid.Column="1"
                                       Placeholder="tu@email.com"
                                       Keyboard="Email"
                                       Text="{Binding Mail}"
                                       BackgroundColor="Transparent"
                                       TextColor="Black"
                                       PlaceholderColor="#999"
                                       FontSize="15"
                                       VerticalOptions="Center"
                                       VerticalTextAlignment="Center" />
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Contraseña -->
                    <VerticalStackLayout Spacing="6" HorizontalOptions="Fill">
                        <Label Text="Contraseña" FontSize="14" TextColor="#222" />
                        <Border BackgroundColor="White"
                                Stroke="#CFCFCF"
                                StrokeThickness="2"
                                HorizontalOptions="Fill"
                                Padding="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="40, *" ColumnSpacing="0" HeightRequest="50">
                                <Label Text="🔒"
                                       FontSize="14"
                                       VerticalOptions="Center"
                                       HorizontalOptions="Center"
                                       Margin="12,0" />
                                <Entry Grid.Column="1"
                                       Placeholder="Mínimo 6 caracteres"
                                       IsPassword="True"
                                       Text="{Binding Password}"
                                       BackgroundColor="Transparent"
                                       TextColor="Black"
                                       PlaceholderColor="#999"
                                       FontSize="15"
                                       VerticalOptions="Center"
                                       VerticalTextAlignment="Center" />
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Verificar contraseña -->
                    <VerticalStackLayout Spacing="6" HorizontalOptions="Fill">
                        <Label Text="Verificar contraseña" FontSize="14" TextColor="#222" />
                        <Border BackgroundColor="White"
                                Stroke="#CFCFCF"
                                StrokeThickness="2"
                                HorizontalOptions="Fill"
                                Padding="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="40, *" ColumnSpacing="0" HeightRequest="50">
                                <Label Text="🔒"
                                       FontSize="14"
                                       VerticalOptions="Center"
                                       HorizontalOptions="Center"
                                       Margin="12,0" />
                                <Entry Grid.Column="1"
                                       Placeholder="Repite tu contraseña"
                                       IsPassword="True"
                                       Text="{Binding VerifyPassword}"
                                       BackgroundColor="Transparent"
                                       TextColor="Black"
                                       PlaceholderColor="#999"
                                       FontSize="15"
                                       VerticalOptions="Center"
                                       VerticalTextAlignment="Center" />
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Botón registrarse estilo similar a LoginPage -->
                    <Button Text="REGISTRARSE"
                            Command="{Binding RegistrarseCommand}"
                            BackgroundColor="Black"
                            TextColor="White"
                            CornerRadius="8"
                            HeightRequest="50"
                            HorizontalOptions="Fill"
                            FontAttributes="Bold"
                            FontSize="16"
                            Margin="0,6,0,0" />

                    <!-- Indicador de carga -->
                    <StackLayout IsVisible="{Binding IsBusy}"
                             Orientation="Horizontal"
                             HorizontalOptions="Center"
                             Spacing="10">
                        <ActivityIndicator IsRunning="{Binding IsBusy}"
                               Color="#666" />
                    </StackLayout>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
