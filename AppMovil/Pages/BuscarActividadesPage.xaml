<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             x:Name="BuscarActividadesPageRoot"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:AppMovil.ViewModels"
             xmlns:pages="clr-namespace:AppMovil.Pages"
             x:Class="AppMovil.Pages.BuscarActividadesPage"
             BackgroundColor="#184D57"
             Title="Buscar Actividades">
    <ContentPage.BindingContext>
        <viewModels:BuscarActividadesViewModel />
    </ContentPage.BindingContext>
    <ScrollView Padding="20">
        <StackLayout Spacing="20">

            <!-- Encabezado -->
            <Frame BackgroundColor="White" 
                   Padding="20" 
                   CornerRadius="15" 
                   HasShadow="True">
                <StackLayout>
                    <Label Text="Buscar Actividades" 
                           FontSize="26" 
                           FontAttributes="Bold"
                           TextColor="#333"
                           HorizontalOptions="Center"/>
                    <Label Text="Encuentra las actividades deportivas del club" 
                           FontSize="14"
                           TextColor="#333"
                           HorizontalOptions="Center"/>
                </StackLayout>
            </Frame>

            <!-- Sección de búsqueda -->
            <Frame BackgroundColor="White" 
                   Padding="15" 
                   CornerRadius="12" 
                   HasShadow="True"
                   BorderColor="LightGray">
                <StackLayout Spacing="15">
                    <Label Text="¿Qué actividades estás buscando?" 
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="DarkSlateGray"/>

                    <!-- SearchBar mejorado -->
                    <Frame BackgroundColor="White" 
                           Padding="5" 
                           CornerRadius="10"
                           HasShadow="False"
                           BorderColor="Gray">
                        <!-- SearchBar para controlar el color del icono -->
                        <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                            <Entry x:Name="searchEntry" Grid.Column="0"
                                   Text="{Binding SearchText}"
                                   Placeholder="Buscar por nombre, profesor o nivel"
                                   PlaceholderColor="Gray"
                                   TextColor="Black"
                                   FontSize="16"
                                   BackgroundColor="Transparent"
                                   VerticalOptions="Center"
                                   HorizontalOptions="FillAndExpand" />

                            <!-- Botón con lupa: usamos un carácter de lupa y aplicamos TextColor para asegurar que se vea -->
                            <Button Grid.Column="1"
                                    Text="🔍"
                                    Command="{Binding BuscarCommand}"
                                    BackgroundColor="Transparent"
                                    TextColor="DarkSlateGray"
                                    FontSize="14"
                                    WidthRequest="44"
                                    HeightRequest="44"
                                    CornerRadius="8"
                                    VerticalOptions="Center"
                                    HorizontalOptions="End" />
                        </Grid>
                    </Frame>
                    
                    <!-- Botón para mostrar/ocultar filtros -->
                    <Button Text="⚙️ Filtros de búsqueda" 
                            Command="{Binding ToggleFiltrosCommand}"
                            BackgroundColor="#557980"
                            TextColor="#333"
                            CornerRadius="8"
                            FontSize="14"/>

                    <!-- Panel de filtros -->
                    <Frame IsVisible="{Binding MostrarFiltros}"
                           BackgroundColor="White" 
                           Padding="12" 
                           CornerRadius="10"
                           HasShadow="False"
                           BorderColor="Gray">
                        <StackLayout Spacing="10">
                            <Label Text="Filtrar por:" 
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="DarkSlateGray"/>

                            <!-- Checkboxes en una sola línea: Nombre (izq), Profesor (centro), Nivel (der) -->
                            <Grid ColumnDefinitions="Auto, *, Auto" RowDefinitions="Auto" VerticalOptions="Center">
                                <StackLayout Grid.Column="0" Grid.Row="0" Orientation="Horizontal" Spacing="8" VerticalOptions="Center">
                                    <CheckBox IsChecked="{Binding FiltrarPorNombre}" Color="#557980" />
                                    <Label Text="🏋🏻‍♀️ Nombre" VerticalOptions="Center" TextColor="DarkSlateGray" />
                                </StackLayout>

                                <StackLayout Grid.Column="1" Grid.Row="0" Orientation="Horizontal" Spacing="12" HorizontalOptions="Center" VerticalOptions="Center">
                                    <CheckBox IsChecked="{Binding FiltrarPorProfesor}" Color="#557980" />
                                    <Label Text="🙋🏻 Profesor" VerticalOptions="Center" TextColor="DarkSlateGray" />
                                </StackLayout>

                                <StackLayout Grid.Column="2" Grid.Row="0" Orientation="Horizontal" Spacing="8" HorizontalOptions="End" VerticalOptions="Center">
                                    <CheckBox IsChecked="{Binding FiltrarPorNivel}" Color="#557980" />
                                    <Label Text="⭐ Nivel" VerticalOptions="Center" TextColor="DarkSlateGray" />
                                </StackLayout>
                            </Grid>

                            <Button Text="🗑️ Limpiar búsqueda" 
                                    Command="{Binding LimpiarCommand}"
                                    BackgroundColor="#B5A35B"
                                    TextColor="White"
                                    CornerRadius="8"
                                    FontSize="14"/>
                        </StackLayout>
                    </Frame>

                    <!-- Indicador de carga -->
                    <StackLayout IsVisible="{Binding IsBusy}" 
                                Orientation="Horizontal" 
                                HorizontalOptions="Center"
                                Spacing="10">
                        <ActivityIndicator IsRunning="{Binding IsBusy}"
                                          Color="DarkSlateGray"/>
                        <Label Text="Buscando actividades..." 
                               TextColor="DarkSlateGray"
                               VerticalOptions="Center"
                               FontSize="14"/>
                    </StackLayout>
                </StackLayout>
            </Frame>

            <!-- Sección de resultados -->
            <StackLayout Spacing="15">
                <!-- Encabezado de resultados -->
                <Frame BackgroundColor="LightSteelBlue" 
                       Padding="12" 
                       CornerRadius="10" 
                       HasShadow="True"
                       BorderColor="#333">
                    <StackLayout>
                        <Label Text="🏋🏻‍♀️ Resultados de búsqueda" 
                               FontSize="18" 
                               FontAttributes="Bold"
                               TextColor="#333"
                               HorizontalOptions="Center"/>
                        <Label Text="{Binding Actividades.Count, StringFormat='{0} actividades encontradas'}"
                               FontSize="14"
                               TextColor="#333"
                               HorizontalOptions="Center"/>
                    </StackLayout>
                </Frame>

                <!-- Lista de actividades en cards mejoradas -->
                <CollectionView ItemsSource="{Binding Actividades}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame BackgroundColor="White" 
                                   Padding="20" 
                                   Margin="0,8"
                                   CornerRadius="15"
                                   HasShadow="True"
                                   BorderColor="LightSteelBlue">
                                <Grid ColumnDefinitions="Auto, *, Auto" 
                                      RowDefinitions="Auto, Auto, Auto, Auto, Auto, Auto, Auto">

                                    <!-- Imagen principal con borde redondeado -->
                                    <Frame Grid.Column="0" Grid.Row="0" Grid.RowSpan="5"
                                           Padding="0"
                                           CornerRadius="12"
                                           HasShadow="False"
                                           IsClippedToBounds="True"
                                           BackgroundColor="#333"
                                           Margin="0,0,15,0"
                                           VerticalOptions="Center"
                                           HorizontalOptions="Center">
                                        <Image Source="{Binding Imagen}"
                                               WidthRequest="99"
                                               HeightRequest="99"
                                               Aspect="AspectFill" />
                                    </Frame>

                                    <!-- Título de la actividad -->
                                    <Label Grid.Column="1" Grid.Row="0"
                                           Text="{Binding Nombre}" 
                                           FontSize="20"
                                           FontAttributes="Bold"
                                           TextColor="#333"
                                           LineBreakMode="WordWrap"/>

                                    <!-- Profesional -->
                                    <StackLayout Grid.Column="1" Grid.Row="1" 
                                                Orientation="Horizontal" 
                                                Spacing="5"
                                                Margin="0,5,0,0">
                                        <Label Text="🙋🏻" FontSize="14"/>
                                        <Label Text="{Binding Profesor.Nombre, StringFormat='A cargo de: {0}'}" 
                                               FontSize="15"
                                               TextColor="Gray"
                                               LineBreakMode="TailTruncation"/>
                                    </StackLayout>
  
                                    <!-- Descripción -->
                                    <Label Grid.Column="1" Grid.Row="4"
                                           Text="{Binding Descripcion}" 
                                           FontSize="15"
                                           TextColor="#333"
                                           LineBreakMode="WordWrap"
                                           MaxLines="2"
                                           Margin="0,8,0,0"/>
                                  
                                    <!-- Nivel y botón de acción (nivel arriba, botón abajo) -->
                                    <StackLayout Grid.Column="2" Grid.Row="0" Grid.RowSpan="5"
                                                Orientation="Vertical"
                                                Spacing="15"
                                                HorizontalOptions="End"
                                                VerticalOptions="FillAndExpand">
                                        <!-- Label de nivel con borde y corner radius -->
                                        <Frame Padding="8,2"
                                               CornerRadius="12"
                                               HasShadow="False"
                                               BackgroundColor="White"
                                               BorderColor="DarkSlateGray"
                                               HorizontalOptions="End"
                                               VerticalOptions="Start"
                                               Margin="0,0,15,0">
                                            <Label Text="{Binding Nivel}"
                                                   FontSize="13"
                                                   FontAttributes="Bold"
                                                   TextColor="DarkSlateGray"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center" />
                                        </Frame>

                                        <Button Text="🗓️&#x0a;Ver"
                                                BackgroundColor="LightSteelBlue"
                                                TextColor="#333"
                                                CornerRadius="12"
                                                FontSize="12"
                                                WidthRequest="55"
                                                HeightRequest="55"
                                                VerticalOptions="End"
                                                Command="{Binding BindingContext.VerActividadCommand, Source={x:Reference BuscarActividadesPageRoot}}"
                                                CommandParameter="{Binding Id}"/>
                                    </StackLayout>


                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Mensaje cuando no hay resultados -->
                <!--<Frame BackgroundColor="LightYellow"
                       Padding="25"
                       CornerRadius="12"
                       HasShadow="True"
                       BorderColor="Orange">
                    <StackLayout>
                        <Label Text="🤔 Sin resultados" 
                               FontSize="20"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               TextColor="DarkOrange"/>
                        <Label Text="Intenta con otros términos de búsqueda o ajusta los filtros"
                               FontSize="14"
                               HorizontalOptions="Center"
                               TextColor="Gray"
                               HorizontalTextAlignment="Center"
                               Margin="0,8,0,0"/>
                        <Label Text="💡 Tip: Usa palabras clave simples y verifica que los filtros apropiados estén seleccionados"
                               FontSize="12"
                               HorizontalOptions="Center"
                               TextColor="Gray"
                               HorizontalTextAlignment="Center"
                               
                               Margin="0,5,0,0"/>
                    </StackLayout>
                </Frame>-->

            </StackLayout>

        </StackLayout>
    </ScrollView>
    

</ContentPage>