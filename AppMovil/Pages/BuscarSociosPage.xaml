<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:AppMovil.ViewModels"
             x:Class="AppMovil.Pages.BuscarSociosPage"
             BackgroundColor="#184D57"
             Title="Buscar Socios">
    <ContentPage.BindingContext>
        <viewModels:BuscarSociosViewModel />
    </ContentPage.BindingContext>
    <ScrollView Padding="20">
        <StackLayout Spacing="20">

            <!-- Encabezado -->
            <Frame BackgroundColor="White" 
                   Padding="20" 
                   CornerRadius="15" 
                   HasShadow="True">
                <StackLayout>
                    <Label Text="Buscar Socios" 
                           FontSize="26" 
                           FontAttributes="Bold"
                           TextColor="#333"
                           HorizontalOptions="Center"/>
                    <Label Text="Encuentra socios y las actividades en las que participan" 
                           FontSize="14"
                           TextColor="#333"
                           HorizontalOptions="Center"/>
                </StackLayout>
            </Frame>

            <!-- Sección de búsqueda -->
            <Frame BackgroundColor="White" 
                   Padding="15" 
                   CornerRadius="12" 
                   HasShadow="True"
                   BorderColor="LightGray">
                <StackLayout Spacing="15">
                    <Label Text="¿Qué socios estás buscando?" 
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="DarkSlateGray"/>
                    
                    <!-- SearchBar mejorado -> Entry + botón para controlar color del icono -->
                    <Frame BackgroundColor="White" 
                           Padding="5" 
                           CornerRadius="10"
                           HasShadow="False"
                           BorderColor="Gray">
                        <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                            <Entry x:Name="searchEntry" Grid.Column="0"
                                   Text="{Binding SearchText}"
                                   Placeholder="Buscar por nombre, dni, actividad o localidad"
                                   PlaceholderColor="Gray"
                                   TextColor="Black"
                                   FontSize="16"
                                   BackgroundColor="Transparent"
                                   VerticalOptions="Center"
                                   HorizontalOptions="FillAndExpand"
                                   Completed="SearchEntry_Completed" />

                            <Button Grid.Column="1"
                                    Text="🔍"
                                    Command="{Binding BuscarCommand}"
                                    BackgroundColor="Transparent"
                                    TextColor="DarkSlateGray"
                                    FontSize="14"
                                    WidthRequest="44"
                                    HeightRequest="44"
                                    CornerRadius="8"
                                    VerticalOptions="Center"
                                    HorizontalOptions="End" />
                        </Grid>
                    </Frame>

                    <!-- Botón para mostrar/ocultar filtros -->
                    <Button Text="⚙️ Filtros de búsqueda" 
                            Command="{Binding ToggleFiltrosCommand}"
                            BackgroundColor="#557980"
                            TextColor="#333"
                            CornerRadius="8"
                            FontSize="14"/>

                    <!-- Panel de filtros (oculto/visible) -->
                    <Frame IsVisible="{Binding MostrarFiltros}"
                           BackgroundColor="White" 
                           Padding="12" 
                           CornerRadius="10"
                           HasShadow="False"
                           BorderColor="Gray">
                        <StackLayout Spacing="10">
                            <Label Text="Filtrar por:" 
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="DarkSlateGray"/>

                            <!-- Checkboxes de filtros reorganizados -->
                            <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto, Auto" ColumnSpacing="12" RowSpacing="10">
                                <!-- Primera fila: Nombre | Dni | Actividad -->
                                <StackLayout Grid.Column="0" Grid.Row="0" Orientation="Horizontal" Spacing="8" VerticalOptions="Center">
                                    <CheckBox IsChecked="{Binding FiltrarPorNombre}" Color="#557980" />
                                    <Label Text="👤 Nombre" VerticalOptions="Center" TextColor="DarkSlateGray" />
                                </StackLayout>

                                <StackLayout Grid.Column="1" Grid.Row="0" Orientation="Horizontal" Spacing="8" HorizontalOptions="Center" VerticalOptions="Center">
                                    <CheckBox IsChecked="{Binding FiltrarPorDni}" Color="#557980" />
                                    <Label Text="🆔 Dni" VerticalOptions="Center" TextColor="DarkSlateGray" />
                                </StackLayout>

                                <StackLayout Grid.Column="2" Grid.Row="0" Orientation="Horizontal" Spacing="8" HorizontalOptions="End" VerticalOptions="Center">
                                    <CheckBox IsChecked="{Binding FiltrarPorActividad}" Color="#557980" />
                                    <Label Text="🏋🏻‍♀️ Actividad" VerticalOptions="Center" TextColor="DarkSlateGray" />
                                </StackLayout>

                                <!-- Segunda fila: Localidad | Activo (dejar columna 3 vacía para equilibrio) -->
                                <StackLayout Grid.Column="0" Grid.Row="1" Orientation="Horizontal" Spacing="8" VerticalOptions="Center">
                                    <CheckBox IsChecked="{Binding FiltrarPorLocalidad}" Color="#557980" />
                                    <Label Text="📍 Localidad" VerticalOptions="Center" TextColor="DarkSlateGray" />
                                </StackLayout>
                            </Grid>
                            <Button Text="🗑️ Limpiar búsqueda" 
                                    Command="{Binding LimpiarCommand}"
                                    BackgroundColor="#B5A35B"
                                    TextColor="White"
                                    CornerRadius="8"
                                    FontSize="14"/>
                        </StackLayout>
                    </Frame>

                    <StackLayout IsVisible="{Binding IsBusy}" 
                                Orientation="Horizontal" 
                                HorizontalOptions="Center"
                                Spacing="10">
                        <ActivityIndicator IsRunning="{Binding IsBusy}"
                                           Color="DarkSlateGray"/>
                        <Label Text="Buscando socios..." 
                               TextColor="DarkSlateGray"
                               VerticalOptions="Center"
                               FontSize="14"/>
                    </StackLayout>
                </StackLayout>
            </Frame>

            <!-- Resultados -->
            <StackLayout Spacing="15">
                <Frame BackgroundColor="LightSteelBlue" 
                       Padding="12" 
                       CornerRadius="10" 
                       HasShadow="True"
                       BorderColor="#333">
                    <StackLayout>
                        <Label Text="🫂 Resultados de búsqueda" 
                               FontSize="18" 
                               FontAttributes="Bold"
                               TextColor="#333"
                               HorizontalOptions="Center"/>
                        <Label Text="{Binding Socios.Count, StringFormat='{0} socios encontrados'}"
                               FontSize="14"
                               TextColor="#333"
                               HorizontalOptions="Center"/>
                    </StackLayout>
                </Frame>

                <CollectionView ItemsSource="{Binding Socios}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame BackgroundColor="White" 
                                   Padding="20" 
                                   Margin="0,8"
                                   CornerRadius="15"
                                   HasShadow="True"
                                   BorderColor="LightSteelBlue">
                                <Grid ColumnDefinitions="Auto, *, Auto" 
                                      RowDefinitions="Auto, Auto, Auto, Auto">

                                    <Label Grid.Column="0" Grid.Row="0" Grid.RowSpan="3"
                                           Text="🫂" 
                                           FontSize="50"
                                           VerticalOptions="Center"
                                           HorizontalOptions="Center"
                                           Margin="0,0,15,0"/>

                                    <Label Grid.Column="1" Grid.Row="0"
                                           Text="{Binding Nombre}" 
                                           FontSize="20"
                                           FontAttributes="Bold"
                                           TextColor="DarkSlateGray"
                                           LineBreakMode="WordWrap"/>

                                    <Label Grid.Column="1" Grid.Row="1"
                                           Text="{Binding Dni, StringFormat='🆔 {0}'}"
                                           FontSize="15"
                                           TextColor="Gray"/>

                                    <Label Grid.Column="1" Grid.Row="2"
                                           Text="{Binding Telefono, StringFormat='📞 {0}'}"
                                           FontSize="15"
                                           TextColor="Gray"/>

                                    <Label Grid.Column="1" Grid.Row="3"
                                           Text="{Binding Actividades}"
                                           FontSize="16"
                                           TextColor="#557980"
                                           FontAttributes="Bold"
                                           LineBreakMode="WordWrap"
                                           MaxLines="2"
                                           Margin="0,8,0,0"/>
                                    

                                    <!-- Información a la derecha: Activo, FechaNacimiento, Localidad -->
                                    <StackLayout Grid.Column="2" Grid.Row="0" Grid.RowSpan="3" Spacing="6" HorizontalOptions="End" VerticalOptions="Center" Margin="0,6,0,0">
                                        <!-- Mostrar 'Activo' o 'Inactivo' usando triggers (no SourceName) -->
                                        <Label FontSize="16" FontAttributes="Bold" HorizontalOptions="End">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding Activo}" Value="True">
                                                    <Setter Property="Text" Value="Activo" />
                                                    <Setter Property="TextColor" Value="#2CA01C" />
                                                </DataTrigger>
                                                <DataTrigger TargetType="Label" Binding="{Binding Activo}" Value="False">
                                                    <Setter Property="Text" Value="Inactivo" />
                                                    <Setter Property="TextColor" Value="#F44336" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>

                                        <!-- Fecha de nacimiento formateada -->
                                        <Label Text="{Binding FechaNacimiento, StringFormat='🗓️ {0:dd/MM/yyyy}'}"
                                               FontSize="15"
                                               TextColor="Gray"
                                               HorizontalOptions="End" />

                                        <!-- Localidad (relación) con icono -->
                                        <HorizontalStackLayout HorizontalOptions="End" Spacing="6" VerticalOptions="Center">
                                            <Label Text="📍" FontSize="14" VerticalOptions="Center" />
                                            <Label Text="{Binding Localidad.Nombre}"
                                                   FontSize="15"
                                                   TextColor="Gray"
                                                   VerticalOptions="Center" />
                                        </HorizontalStackLayout>
                                    </StackLayout>

                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </StackLayout>

        </StackLayout>
    </ScrollView>

</ContentPage>