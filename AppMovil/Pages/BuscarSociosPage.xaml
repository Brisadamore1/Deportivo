<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:AppMovil.ViewModels"
             x:Class="AppMovil.Pages.BuscarSociosPage"
             BackgroundColor="#184D57"
             Title="Buscar Socios">
    <ContentPage.BindingContext>
        <viewModels:BuscarSociosViewModel />
    </ContentPage.BindingContext>
    <ScrollView Padding="20">
        <StackLayout Spacing="20">

            <!-- Encabezado -->
            <Frame BackgroundColor="White" 
                   Padding="20" 
                   CornerRadius="15" 
                   HasShadow="True">
                <StackLayout>
                    <Label Text="Buscar Socios" 
                           FontSize="26" 
                           FontAttributes="Bold"
                           TextColor="#333"
                           HorizontalOptions="Center"/>
                    <Label Text="Encuentra socios y las actividades en las que participan" 
                           FontSize="14"
                           TextColor="#333"
                           HorizontalOptions="Center"/>
                </StackLayout>
            </Frame>

            <!-- Sección de búsqueda -->
            <Frame BackgroundColor="White" 
                   Padding="15" 
                   CornerRadius="12" 
                   HasShadow="True"
                   BorderColor="LightGray">
                <StackLayout Spacing="15">
                    <Label Text="¿Qué socios estás buscando?" 
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="DarkSlateGray"/>

                    <Frame BackgroundColor="WhiteSmoke" 
                           Padding="5" 
                           CornerRadius="10"
                           HasShadow="False"
                           BorderColor="LightBlue">
                        <SearchBar Placeholder="Buscar por nombre y dni..." 
                                   Text="{Binding SearchText}"
                                   SearchCommand="{Binding BuscarCommand}"
                                   BackgroundColor="Transparent"
                                   PlaceholderColor="Gray"
                                   TextColor="Black"
                                   FontSize="16"/>
                    </Frame>

                    <Grid ColumnDefinitions="*" RowDefinitions="Auto">

                        <StackLayout Grid.Column="0" Grid.Row="0" Orientation="Horizontal" Spacing="8">
                            <CheckBox IsChecked="{Binding FiltrarPorDni}" Color="DodgerBlue"/>
                            <Label Text="📖 Dni" 
                            VerticalOptions="Center"
                            TextColor="DarkSlateGray"/>
                        </StackLayout>
                    </Grid>
                    <Button Text="Limpiar" 
                            Command="{Binding LimpiarCommand}"
                            BackgroundColor="Orange"
                            TextColor="White"
                            CornerRadius="8"
                            FontSize="14"/>

                    <StackLayout IsVisible="{Binding IsBusy}" 
                                Orientation="Horizontal" 
                                HorizontalOptions="Center"
                                Spacing="10">
                        <ActivityIndicator IsRunning="{Binding IsBusy}"
                                           Color="DodgerBlue"/>
                        <Label Text="Buscando socios..." 
                               TextColor="DodgerBlue"
                               VerticalOptions="Center"
                               FontSize="14"/>
                    </StackLayout>
                </StackLayout>
            </Frame>

            <!-- Resultados -->
            <StackLayout Spacing="15">
                <Frame BackgroundColor="LightSteelBlue" 
                       Padding="12" 
                       CornerRadius="10" 
                       HasShadow="True"
                       BorderColor="#333">
                    <StackLayout>
                        <Label Text="Resultados de búsqueda" 
                               FontSize="18" 
                               FontAttributes="Bold"
                               TextColor="#333"
                               HorizontalOptions="Center"/>
                        <Label Text="{Binding Socios.Count, StringFormat='{0} socios encontrados'}"
                               FontSize="14"
                               TextColor="#333"
                               HorizontalOptions="Center"/>
                    </StackLayout>
                </Frame>

                <CollectionView ItemsSource="{Binding Socios}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame BackgroundColor="White" 
                                   Padding="20" 
                                   Margin="0,8"
                                   CornerRadius="15"
                                   HasShadow="True"
                                   BorderColor="LightSteelBlue">
                                <Grid ColumnDefinitions="Auto, *, Auto" 
                                      RowDefinitions="Auto, Auto, Auto, Auto">

                                    <Label Grid.Column="0" Grid.Row="0" Grid.RowSpan="3"
                                           Text="Usuario" 
                                           FontSize="20"
                                           VerticalOptions="Center"
                                           HorizontalOptions="Center"
                                           Margin="0,0,15,0"/>

                                    <Label Grid.Column="1" Grid.Row="0"
                                           Text="{Binding Nombre}" 
                                           FontSize="18"
                                           FontAttributes="Bold"
                                           TextColor="DarkSlateGray"
                                           LineBreakMode="WordWrap"/>

                                    <Label Grid.Column="1" Grid.Row="1"
                                           Text="{Binding Dni, StringFormat='DNI: {0}'}"
                                           FontSize="14"
                                           TextColor="Gray"/>

                                    <Label Grid.Column="1" Grid.Row="2"
                                           Text="{Binding Telefono, StringFormat='Tel: {0}'}"
                                           FontSize="14"
                                           TextColor="Gray"/>

                                    <Label Grid.Column="1" Grid.Row="3"
                                           Text="{Binding Actividades}"
                                           FontSize="13"
                                           TextColor="DarkGray"
                                           LineBreakMode="WordWrap"
                                           MaxLines="2"
                                           Margin="0,8,0,0"/>

                                    <Button Grid.Column="2" Grid.Row="0" Grid.RowSpan="4"
                                            Text="Ver"
                                            BackgroundColor="LightBlue"
                                            TextColor="DarkBlue"
                                            CornerRadius="10"
                                            FontSize="12"
                                            WidthRequest="60"
                                            HeightRequest="60"
                                            VerticalOptions="Center"/>

                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </StackLayout>

        </StackLayout>
    </ScrollView>

</ContentPage>