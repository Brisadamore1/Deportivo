<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="AppMovil.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:AppMovil"
    xmlns:viewModels="clr-namespace:AppMovil.ViewModels"
    xmlns:pages="clr-namespace:AppMovil.Pages"
    Shell.FlyoutBehavior="Disabled"
    Title="Deportivo">

    <Shell.BindingContext>
        <viewModels:AppShellViewModel/>
    </Shell.BindingContext>

    <!-- Recursos: estilo reutilizable para items del Flyout (simplifica plantilla) -->
    <Shell.Resources>
        <ResourceDictionary>
            <Style x:Key="FlyoutItemFrameStyle" TargetType="Frame">
                <Setter Property="HasShadow" Value="False" />
                <Setter Property="Padding" Value="8,10" />
                <Setter Property="Margin" Value="4,2" />
                <Setter Property="BackgroundColor" Value="Transparent" />
                <Setter Property="BorderColor" Value="Transparent" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="VisualStateManager.VisualStateGroups">
                    <VisualStateGroupList>
                        <VisualStateGroup Name="CommonStates">
                            <VisualState Name="Normal">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="Transparent" />
                                    <Setter Property="CornerRadius" Value="8" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState Name="Selected">
                                <VisualState.Setters>
                                    <!-- Fondo gris claro y borde redondeado cuando el item del flyout está seleccionado -->
                                    <Setter Property="BackgroundColor" Value="#E6E6E6" />
                                    <Setter Property="BorderColor" Value="#D0D0D0" />
                                    <Setter Property="CornerRadius" Value="22" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateGroupList>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Shell.Resources>

    <!-- Encabezado del Flyout con imagen de fondo (usa la imagen "logo.png" en Resources/Images) -->
    <Shell.FlyoutHeader>
        <Grid HeightRequest="200">
            <!-- Imagen de fondo -->
            <Image Source="fondo.jpg" Aspect="AspectFill" Opacity="1" />

            <!-- Contenido superpuesto -->
            <StackLayout VerticalOptions="Center" HorizontalOptions="Center" BackgroundColor="Transparent">
                <Label Text="Gestión Deportiva" FontSize="20" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center"/>
            </StackLayout>
        </Grid>
    </Shell.FlyoutHeader>

    <!-- Pantalla de Login -->
    <ShellContent
         Title="Login"
         ContentTemplate="{DataTemplate pages:LoginPage}"
         Route="LoginPage"
         FlyoutItemIsVisible="False" />
    <ShellContent
         Title="Reseteo de Password"
         ContentTemplate="{DataTemplate pages:RecuperarPasswordPage}"
         Route="ResetPassword"
         FlyoutItemIsVisible="False" />
    <ShellContent
         Title="Crear cuenta"
         ContentTemplate="{DataTemplate pages:RegistrarsePage}"
         Route="RegistrarsePage"
         FlyoutItemIsVisible="False" />

    <!-- Página para mostrar las clases de una actividad (no aparece en el flyout) -->
    <ShellContent
         Title="Clases"
         ContentTemplate="{DataTemplate pages:ClasesPage}"
         Route="ClasesPage"
         FlyoutItemIsVisible="False" />
    

    <!-- Menu Principal - Solo visible cuando está logueado -->
    <FlyoutItem Title="🏠 Inicio" Icon="home.png" >
        <ShellContent
         Title="Dashboard"
         ContentTemplate="{DataTemplate pages:MainPage}"
         Route="MainPage" />
    </FlyoutItem>

    <FlyoutItem Title="🏋🏻‍♀️ Buscar Actividades" Icon="search.png">
        <ShellContent
        Title="Buscar Actividades"
        ContentTemplate="{DataTemplate pages:BuscarActividadesPage}"
        Route="BuscarActividadesPage" />
    </FlyoutItem>

    <FlyoutItem Title="🫂 Buscar Socios" Icon="search.png">
        <ShellContent
        Title="Buscar Socios"
        ContentTemplate="{DataTemplate pages:BuscarSociosPage}"
        Route="BuscarSociosPage" />
    </FlyoutItem>


    <!-- Footer del Flyout con opción de logout -->
    <Shell.FlyoutFooter>
        <StackLayout BackgroundColor="#F5F5F5" Padding="10">
            <Button 
             Text="🚪 Cerrar Sesion" 
             BackgroundColor="#F44336" 
             TextColor="White"
             Command="{Binding LogoutCommand}"
             CornerRadius="5"/>
        </StackLayout>
    </Shell.FlyoutFooter>

</Shell>
